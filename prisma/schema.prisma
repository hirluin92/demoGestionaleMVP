generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// TENANT (attività: salone, centro estetico, ecc.)
// ==========================================
enum Plan {
  SOLO
  PRO
  STUDIO
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

model Tenant {
  id                String        @id @default(cuid())
  slug              String        @unique    // URL-friendly: /mio-salone
  name              String                   // "Salone Sara"
  category          String                   // parrucchiere, estetista, dentista...
  city              String
  phone             String?
  email             String
  logoUrl           String?
  plan              Plan          @default(PRO)
  status            TenantStatus  @default(TRIAL)
  trialEndsAt       DateTime?
  stripeCustomerId  String?       @unique
  stripeSubId       String?       @unique
  settings          Json          @default("{}")
  // settings contiene: businessHours, timezone, locale, etc.
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  users             User[]
  staff             Staff[]
  services          Service[]
  clients           Client[]
  appointments      Appointment[]
  messageLog        MessageLog[]

  @@index([slug])
}

// ==========================================
// USER (account login — separato da Staff)
// ==========================================
enum UserRole {
  SUPER_ADMIN    // Noi (Appointly admin)
  TENANT_OWNER   // Titolare
  STAFF          // Dipendente con login
}

model User {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email             String    @unique
  passwordHash      String
  name              String
  role              UserRole  @default(STAFF)
  staffId           String?   @unique
  staff             Staff?    @relation(fields: [staffId], references: [id])
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())

  @@index([tenantId])
  @@index([email])
}

// ==========================================
// STAFF (operatore: chi esegue i servizi)
// ==========================================
model Staff {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  color          String        @default("#3B82F6") // Colore nel calendario
  isActive       Boolean       @default(true)
  workingHours   Json          @default("{}")
  // workingHours formato:
  // { "mon": { "start": "09:00", "end": "18:00", "break": { "start": "13:00", "end": "14:00" } },
  //   "tue": { ... }, "wed": null (= giorno libero) }
  createdAt      DateTime      @default(now())

  user           User?
  appointments   Appointment[]
  serviceLinks   StaffService[]

  @@index([tenantId])
}

// ==========================================
// SERVICE (servizio offerto: taglio, piega, ecc.)
// ==========================================
model Service {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String                    // "Taglio Uomo"
  duration       Int                       // Minuti
  price          Int                       // Centesimi (€25.00 = 2500)
  color          String        @default("#8B5CF6")
  isActive       Boolean       @default(true)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())

  appointments   Appointment[]
  staffLinks     StaffService[]

  @@index([tenantId])
}

// Relazione N:M — quali operatori fanno quali servizi
model StaffService {
  staffId    String
  staff      Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}

// ==========================================
// CLIENT (cliente dell'attività — NON utente Appointly)
// ==========================================
model Client {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  phone           String
  email           String?
  optInMarketing  Boolean       @default(false)  // Consenso promozioni (GDPR)
  optInReminders  Boolean       @default(true)   // Consenso promemoria (GDPR)
  loyaltyPoints   Int           @default(0)
  totalVisits     Int           @default(0)
  totalSpent      Int           @default(0)      // Centesimi
  lastVisitAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  appointments    Appointment[]
  notes           ClientNote[]

  @@unique([tenantId, phone])   // Stesso telefono = stesso cliente per tenant
  @@index([tenantId])
  @@index([tenantId, name])
}

// ==========================================
// CLIENT NOTE (note, preferenze, allergie)
// ==========================================
enum NoteType {
  GENERAL
  ALLERGY
  PREFERENCE
  HISTORY
  VOICE        // Nota vocale trascritta da Claude API
}

model ClientNote {
  id         String    @id @default(cuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type       NoteType  @default(GENERAL)
  content    String
  createdAt  DateTime  @default(now())

  @@index([clientId])
}

// ==========================================
// APPOINTMENT (il cuore del sistema)
// ==========================================
enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Appointment {
  id              String              @id @default(cuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client              @relation(fields: [clientId], references: [id])
  staffId         String
  staff           Staff               @relation(fields: [staffId], references: [id])
  serviceId       String
  service         Service             @relation(fields: [serviceId], references: [id])
  startTime       DateTime
  endTime         DateTime            // Calcolato: startTime + service.duration
  status          AppointmentStatus   @default(SCHEDULED)
  price           Int                 // Prezzo snapshot al momento della prenotazione (centesimi)
  notes           String?
  reminderSentAt  DateTime?           // Quando il promemoria WhatsApp è stato inviato
  confirmedAt     DateTime?           // Quando il cliente ha confermato
  cancelledAt     DateTime?
  source          String              @default("manual") // manual, online, phone, whatsapp
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([tenantId, startTime])
  @@index([tenantId, staffId, startTime])
  @@index([tenantId, clientId])
  @@index([tenantId, status])
}

// ==========================================
// MESSAGE LOG (tracciamento messaggi inviati per billing)
// ==========================================
enum MessageChannel {
  WHATSAPP
  SMS
  VOICE
  EMAIL
}

enum MessageType {
  REMINDER
  CONFIRMATION
  CANCELLATION
  MARKETING
  CALLBACK
}

model MessageLog {
  id             String          @id @default(cuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointmentId  String?
  clientPhone    String
  channel        MessageChannel
  type           MessageType
  content        String?
  twilioSid      String?         // SID messaggio Twilio per tracking
  status         String          @default("sent") // sent, delivered, read, failed
  costCents      Int             @default(0)      // Costo in centesimi di euro
  sentAt         DateTime        @default(now())

  @@index([tenantId])
  @@index([tenantId, sentAt])
}
